# Database
DATABASE_URL=postgresql+asyncpg://mathapp:mathapp@localhost:5432/mathapp

# Auth
JWT_SECRET=change-me-to-a-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Claude API
CLAUDE_API_KEY=sk-ant-your-key-here

# Mathpix (deferred to v2)
# MATHPIX_APP_ID=
# MATHPIX_APP_KEY=

# Sentry
SENTRY_DSN=https://your-dsn@sentry.io/your-project

# App
APP_ENV=development
LOG_LEVEL=DEBUG
CORS_ORIGINS=["http://localhost:8081","http://localhost:3000"]

# Rate Limits
DAILY_REQUEST_CAP_FREE=50
DAILY_REQUEST_CAP_SCHOOL=500

# Cost Alerting
DAILY_COST_LIMIT_USD=50.0
