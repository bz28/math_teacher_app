# Database
DATABASE_URL=postgresql+asyncpg://mathapp:mathapp@localhost:5432/mathapp

# Auth
JWT_SECRET=change-me-to-a-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Claude API
CLAUDE_API_KEY=sk-ant-your-key-here

# OpenAI API Key
OPENAI_API_KEY=sk-proj-1234567890

# Sentry
SENTRY_DSN=

# App
APP_ENV=development
LOG_LEVEL=DEBUG
CORS_ORIGINS=["http://localhost:8081","http://localhost:3000"]

# Rate Limits
DAILY_REQUEST_CAP_FREE=50

# Cost Alerting
DAILY_COST_LIMIT_USD=50.0

# Email (Resend) — for admin notifications
RESEND_API_KEY=re_your_key_here
ADMIN_ALERT_EMAIL=you@example.com
EMAIL_FROM_ADDRESS=Math Tutor <alerts@mathtutor.app>
